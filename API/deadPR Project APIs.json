		},
		{
			"name": "Admin",
			"item": [
				{
					"name": "Admin: Create New Trainer",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{admin_jwt}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Aman The Trainer\",\n    \"email\": \"aman.trainer@example.com\",\n    \"password\": \"aman@123\",\n    \"phoneNumber\": \"9998887776\",\n    \"description\": \"Certified Powerlifting coach with 5 years of experience.\",\n    \"specializations\": [\"Powerlifting\", \"Strength Training\"]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/admin/trainers",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"admin",
								"trainers"
							]
						}
					},
					"response": []
				},
				{
					"name": "Admin: Create New Package",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{admin_jwt}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"1 Month Powerlifting Basics\",\n    \"description\": \"A beginner-friendly plan to build a strong foundation in squats, bench press, and deadlifts.\",\n    \"price\": 2500,\n    \"durationInDays\": 30,\n    \"trainerId\": \"{{trainerId}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/admin/packages",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"admin",
								"packages"
							]
						}
					},
					"response": []
				}
			]
		}
	],
