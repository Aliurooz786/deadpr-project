		{
			"name": "Public",
			"item": [
				{
					"name": "Get All Trainers",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/public/trainers",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"public",
								"trainers"
							]
						},
						"description": "Fetches a list of all trainer profiles. No authentication needed."
					},
					"response": []
				},
				{
					"name": "Get Trainer By ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/public/trainers/{{trainerId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"public",
								"trainers",
								"{{trainerId}}"
							]
						},
						"description": "Fetches the profile of a single trainer. Replace `{{trainerId}}` with a real ID from your database. No authentication needed."
					},
					"response": []
				}
			]
		},
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register New User (Client)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test Client\",\n    \"email\": \"client@example.com\",\n    \"password\": \"client@123\",\n    \"phoneNumber\": \"1234567890\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"register"
							]
						}
					},
					"response": []
				},
